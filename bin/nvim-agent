#!/bin/sh

detect_agent_from_parents() {
    pid="$PPID"

    while [ -n "$pid" ] && [ "$pid" -gt 1 ] 2>/dev/null; do
        cmd="$(ps -p "$pid" -o command= 2>/dev/null || true)"

        case "$cmd" in
            *claude*)
                printf '%s\n' "claude"
                return 0
                ;;
            *codex*)
                printf '%s\n' "codex"
                return 0
                ;;
        esac

        pid="$(ps -p "$pid" -o ppid= 2>/dev/null | tr -d '[:space:]')"
        case "$pid" in
            ''|*[!0-9]*)
                break
                ;;
        esac
    done
}

capture_shell_context() {
    case "${DOTAGENT_AGENT:-}" in
        claude|codex)
            ;;
        *)
            return 0
            ;;
    esac

    [ -z "${NVIM_PRE_SHELL_CONTEXT:-}" ] || return 0
    [ "${NVIM_AGENT_SHELL_CONTEXT:-1}" != "0" ] || return 0
    [ -n "${TMUX:-}" ] || return 0
    command -v tmux >/dev/null 2>&1 || return 0

    lines="${NVIM_AGENT_SHELL_CONTEXT_LINES:-200}"
    case "$lines" in
        ''|*[!0-9]*)
            lines=200
            ;;
    esac

    context_file="$(mktemp "${TMPDIR:-/tmp}/nvim-shell-context.XXXXXX" 2>/dev/null)" || return 0
    target="${NVIM_AGENT_TMUX_PANE:-${TMUX_PANE:-}}"

    if [ -n "$target" ]; then
        tmux capture-pane -p -J -S "-$lines" -t "$target" >"$context_file" 2>/dev/null || true
    else
        tmux capture-pane -p -J -S "-$lines" >"$context_file" 2>/dev/null || true
    fi

    if [ -s "$context_file" ]; then
        export NVIM_PRE_SHELL_CONTEXT="$context_file"
        export NVIM_PRE_SHELL_CONTEXT_DELETE=1
    else
        rm -f "$context_file"
    fi
}

agent="${DOTAGENT_AGENT:-$(detect_agent_from_parents)}"

case "$agent" in
    claude|claude-code)
        export DOTAGENT_EDITOR_PROMPT="${DOTAGENT_EDITOR_PROMPT:-1}"
        export DOTAGENT_AGENT="claude"
        export DOTAGENT_PREFIX="${DOTAGENT_PREFIX:-/}"
        ;;
    codex)
        export DOTAGENT_EDITOR_PROMPT="${DOTAGENT_EDITOR_PROMPT:-1}"
        export DOTAGENT_AGENT="codex"
        export DOTAGENT_PREFIX="${DOTAGENT_PREFIX:-\$}"
        ;;
esac

capture_shell_context

exec "${NVIM_AGENT_NVIM:-nvim}" "$@"
